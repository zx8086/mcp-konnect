# ===========================
# Kong Konnect MCP Server Configuration Example
# Copy this file to .env and fill in your actual values
# ===========================

# Application Configuration
APPLICATION_NAME=kong-konnect-mcp
APPLICATION_VERSION=2.0.0
NODE_ENV=development
LOG_LEVEL=info

# Kong Konnect API Configuration
# REQUIRED: Get your access token from https://cloud.konghq.com/
KONNECT_ACCESS_TOKEN=your-kong-konnect-access-token-here
# Optional: API region (us, eu, au, me, in) - defaults to 'us'
KONNECT_REGION=us
# Optional: API timeout in milliseconds - defaults to 30000 (30 seconds)
KONNECT_TIMEOUT=30000
# Optional: Number of retry attempts - defaults to 3
KONNECT_RETRY_ATTEMPTS=3
# Optional: Delay between retries in milliseconds - defaults to 1000 (1 second)
KONNECT_RETRY_DELAY=1000

# LangSmith Tracing Configuration
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=konnect-mcp-server
# Optional: Session name for tracing - defaults to 'mcp-session'
LANGSMITH_SESSION=mcp-session
# Optional: Comma-separated tags - defaults to 'mcp-server,kong-konnect'
LANGSMITH_TAGS=mcp-server,kong-konnect,development
# Optional: Sampling rate (0.0 to 1.0) - defaults to 1.0
LANGSMITH_SAMPLING_RATE=1.0

# Monitoring and Performance Configuration
# Optional: Enable performance monitoring - defaults to true
MONITORING_ENABLED=true
# Optional: Health check interval in milliseconds - defaults to 30000 (30 seconds)
HEALTH_CHECK_INTERVAL=30000
# Optional: Enable metrics collection - defaults to true
METRICS_COLLECTION=true
# Optional: Performance thresholds
PERFORMANCE_RESPONSE_TIME_MS=5000
PERFORMANCE_ERROR_RATE=5

# Runtime Configuration
# Optional: Prefer Bun.env over process.env - defaults to true
PREFER_BUN_ENV=true
# Optional: Auto-load .env files - defaults to true
ENV_FILE_AUTO_LOAD=true
# Optional: Enable debug mode - defaults to false
DEBUG_MODE=false